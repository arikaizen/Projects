# OAuth 2.1 Authorization Server configuration
HOST=0.0.0.0
PORT=8080

# Base URL of THIS server (used in JWT iss claim and discovery document)
AUTH_SERVER_ISSUER=http://localhost:8080

# Audience claim embedded in issued access tokens — must match MCP_SERVER_AUDIENCE
MCP_SERVER_AUDIENCE=http://localhost:8081

# Token lifetimes (seconds)
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=86400
