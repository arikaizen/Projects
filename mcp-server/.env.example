# MCP Server configuration
HOST=0.0.0.0
PORT=8081

# Auth server introspection endpoint (step ④)
AUTH_INTROSPECT_URL=http://localhost:8080/introspect

# Expected audience in incoming Bearer tokens
MCP_SERVER_AUDIENCE=http://localhost:8081

# Required scope for tool calls
MCP_REQUIRED_SCOPE=tools:call

# ── Data source service credentials (step ⑤–⑥) ────────────────────────────────
# These are the MCP server's own scoped credentials.
# They are NEVER forwarded to the LLM or the user.

# Graph database (data server/)
GRAPH_DB_HOST=localhost
GRAPH_DB_PORT=7474

# SIEM (siem/main/)
SIEM_BASE_URL=http://localhost:5000
SIEM_API_KEY=

# Asset map (asset map/)
ASSET_MAP_BASE_URL=http://localhost:8000
ASSET_MAP_API_KEY=
