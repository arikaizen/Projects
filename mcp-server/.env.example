# MCP Server configuration
HOST=0.0.0.0
PORT=8081

# Auth server introspection endpoint (step ④)
AUTH_INTROSPECT_URL=http://localhost:8080/introspect

# Expected audience in incoming Bearer tokens
MCP_SERVER_AUDIENCE=http://localhost:8081

# Required scope for tool calls
MCP_REQUIRED_SCOPE=tools:call

# Tool script locations
TOOLS_DIR=../tools
TOOLS_MANIFEST=../tools/tools_manifest.json

# ── API Keys (step ⑤–⑥ — server-side credentials, never sent to the model) ──

# Google APIs (Search, Maps, Translate, YouTube, Vision, NLP)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=          # Custom Search Engine ID for web_search tools

# OpenWeatherMap
OPENWEATHER_API_KEY=

# NewsAPI.org
NEWSAPI_KEY=

# Alpha Vantage (stocks, FX, crypto)
ALPHA_VANTAGE_KEY=

# GitHub (optional — increases rate limits)
GITHUB_TOKEN=

# DeepL Translation
DEEPL_API_KEY=

# Wolfram Alpha
WOLFRAM_APP_ID=

# YouTube Data API (falls back to GOOGLE_API_KEY if not set)
YOUTUBE_API_KEY=

# Unsplash
UNSPLASH_ACCESS_KEY=

# ipinfo.io (optional — increases rate limits)
IPINFO_TOKEN=

# ── stdio mode ────────────────────────────────────────────────────────────────
# Set to any non-empty value to switch from HTTP to stdin/stdout mode
# STDIN_STDIO=1
