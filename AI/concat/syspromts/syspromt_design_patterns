    struct ICompressor {
        virtual ~ICompressor() = default;
        virtual std::vector<uint8_t> compress(std::span<const uint8_t> input)   = 0;
        virtual std::vector<uint8_t> decompress(std::span<const uint8_t> input) = 0;
        virtual std::string          codec_name() const = 0;
    };

    struct ZlibCompressor  : ICompressor {
        std::vector<uint8_t> compress(std::span<const uint8_t>)   override { return {}; }
        std::vector<uint8_t> decompress(std::span<const uint8_t>) override { return {}; }
        std::string          codec_name() const override { return "zlib"; }
    };

    struct LZ4Compressor : ICompressor {
        std::vector<uint8_t> compress(std::span<const uint8_t>)   override { return {}; }
        std::vector<uint8_t> decompress(std::span<const uint8_t>) override { return {}; }
        std::string          codec_name() const override { return "lz4"; }
    };

    class CompressorFactory {
    public:
        using Creator = std::function<std::unique_ptr<ICompressor>()>;

        // Meyers Singleton
        static CompressorFactory& instance() {
            static CompressorFactory inst;
            return inst;
        }

        void register_codec(std::string name, Creator creator) {
            std::unique_lock lock(rw_mutex_);
            if (creators_.count(name)) throw std::runtime_error("Codec already registered: " + name);
            creators_[std::move(name)] = std::move(creator);
        }

        [[nodiscard]]
        std::unique_ptr<ICompressor> create(const std::string& name) const {
            std::shared_lock lock(rw_mutex_);
            auto it = creators_.find(name);
            if (it == creators_.end()) throw std::runtime_error("Unknown codec: " + name);
            return it->second();
        }

        std::vector<std::string> available_codecs() const {
            std::shared_lock lock(rw_mutex_);
            std::vector<std::string> names;
            names.reserve(creators_.size());
            for (const auto& [k, _] : creators_) names.push_back(k);
            return names;
        }

        CompressorFactory(const CompressorFactory&)            = delete;
        CompressorFactory& operator=(const CompressorFactory&) = delete;

    private:
        CompressorFactory() {
            // Register built-in codecs at construction time (single thread, safe)
            creators_["zlib"] = []{ return std::make_unique<ZlibCompressor>(); };
            creators_["lz4"]  = []{ return std::make_unique<LZ4Compressor>(); };
        }
        mutable std::shared_mutex rw_mutex_;
        std::unordered_map<std::string, Creator> creators_;
    };

    // Usage:
    // auto& factory = CompressorFactory::instance();
    // auto c = factory.create("zlib");
