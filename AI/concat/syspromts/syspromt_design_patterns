    class TSSerializerFactory {
    public:
        using Creator = std::function<std::unique_ptr<ISerializer>()>;

        void register_creator(const std::string& name, Creator creator) {
            std::unique_lock lock(mutex_);
            creators_[name] = std::move(creator);
        }

        std::unique_ptr<ISerializer> create(const std::string& name) const {
            std::shared_lock lock(mutex_);
            auto it = creators_.find(name);
            if (it == creators_.end()) throw std::runtime_error("Unknown: " + name);
            return it->second();  // creator is called inside lock — keep creators fast
        }

    private:
        mutable std::shared_mutex mutex_;
        std::unordered_map<std::string, Creator> creators_;
    };

