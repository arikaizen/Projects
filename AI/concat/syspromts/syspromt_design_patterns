    // Product interfaces
    struct IButton  { virtual void render() = 0; virtual ~IButton()  = default; };
    struct ITextBox { virtual void render() = 0; virtual ~ITextBox() = default; };

    // Abstract factory
    struct IUIFactory {
        virtual std::unique_ptr<IButton>  create_button()  = 0;
        virtual std::unique_ptr<ITextBox> create_textbox() = 0;
        virtual ~IUIFactory() = default;
    };

    // Windows family
    struct WinButton  : IButton  { void render() override { /* Win32 */ } };
    struct WinTextBox : ITextBox { void render() override { /* Win32 */ } };
    struct WinFactory : IUIFactory {
        std::unique_ptr<IButton>  create_button()  override { return std::make_unique<WinButton>(); }
        std::unique_ptr<ITextBox> create_textbox() override { return std::make_unique<WinTextBox>(); }
    };

    // Mac family
    struct MacButton  : IButton  { void render() override { /* Cocoa */ } };
    struct MacTextBox : ITextBox { void render() override { /* Cocoa */ } };
    struct MacFactory : IUIFactory {
        std::unique_ptr<IButton>  create_button()  override { return std::make_unique<MacButton>(); }
        std::unique_ptr<ITextBox> create_textbox() override { return std::make_unique<MacTextBox>(); }
    };

    // Application — depends only on IUIFactory
    class Application {
    public:
        explicit Application(std::unique_ptr<IUIFactory> factory)
            : button_(factory->create_button()), textbox_(factory->create_textbox()) {}
        void render() { button_->render(); textbox_->render(); }
    private:
        std::unique_ptr<IButton>  button_;
        std::unique_ptr<ITextBox> textbox_;
    };

