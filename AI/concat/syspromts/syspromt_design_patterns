    #include <memory>
    #include <string>
    #include <stdexcept>

    struct ISerializer {
        virtual ~ISerializer() = default;
        virtual std::string serialize(const std::string& data)   = 0;
        virtual std::string deserialize(const std::string& raw)  = 0;
    };

    struct JsonSerializer : ISerializer {
        std::string serialize(const std::string& data)   override { return "{\"data\":\"" + data + "\"}"; }
        std::string deserialize(const std::string& raw)  override { return raw; }
    };

    struct XmlSerializer : ISerializer {
        std::string serialize(const std::string& data)   override { return "<data>" + data + "</data>"; }
        std::string deserialize(const std::string& raw)  override { return raw; }
    };

    // Factory Method — free function form
    std::unique_ptr<ISerializer> make_serializer(std::string_view type) {
        if (type == "json") return std::make_unique<JsonSerializer>();
        if (type == "xml")  return std::make_unique<XmlSerializer>();
        throw std::invalid_argument("Unknown serializer: " + std::string(type));
    }

