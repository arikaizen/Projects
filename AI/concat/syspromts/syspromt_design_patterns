    class ThreadSafeLogger {
    public:
        static ThreadSafeLogger& instance() {
            static ThreadSafeLogger inst;  // C++11 guarantees thread-safe initialization
            return inst;
        }
        void log(std::string_view msg) {
            std::lock_guard<std::mutex> lock(mutex_);
            entries_.emplace_back(msg);
            std::clog << "[LOG] " << msg << '\n';
        }
        std::vector<std::string> dump() const {
            std::lock_guard<std::mutex> lock(mutex_);
            return entries_;  // copy under lock
        }
        ThreadSafeLogger(const ThreadSafeLogger&)            = delete;
        ThreadSafeLogger& operator=(const ThreadSafeLogger&) = delete;
    private:
        ThreadSafeLogger() = default;
        mutable std::mutex mutex_;
        std::vector<std::string> entries_;
    };

