    struct ISerializer {
        virtual ~ISerializer() = default;
        virtual std::string serialize(const std::string& data)  = 0;
        virtual std::unique_ptr<ISerializer> clone() const      = 0;
    };

    struct JsonSerializer : ISerializer {
        std::string serialize(const std::string& data) override {
            return "{\"data\":\"" + data + "\"}";
        }
        std::unique_ptr<ISerializer> clone() const override {
            return std::make_unique<JsonSerializer>(*this);
        }
    };

    class SerializerFactory {
    public:
        static SerializerFactory& instance() {
            static SerializerFactory inst;
            return inst;
        }
        void register_type(const std::string& name, std::unique_ptr<ISerializer> proto) {
            prototypes_[name] = std::move(proto);
        }
        std::unique_ptr<ISerializer> create(const std::string& name) const {
            auto it = prototypes_.find(name);
            if (it == prototypes_.end()) throw std::runtime_error("Unknown type: " + name);
            return it->second->clone();
        }
        SerializerFactory(const SerializerFactory&)            = delete;
        SerializerFactory& operator=(const SerializerFactory&) = delete;
    private:
        SerializerFactory() {
            prototypes_["json"] = std::make_unique<JsonSerializer>();
        }
        std::unordered_map<std::string, std::unique_ptr<ISerializer>> prototypes_;
    };

