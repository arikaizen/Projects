    #include <shared_mutex>
    #include <atomic>

    // Full render-backend abstract factory, thread-safe singleton

    struct IMesh    { virtual void upload()   = 0; virtual ~IMesh()    = default; };
    struct ITexture { virtual void bind()     = 0; virtual ~ITexture() = default; };
    struct IShader  { virtual void compile()  = 0; virtual ~IShader()  = default; };

    struct IRenderFactory {
        virtual std::unique_ptr<IMesh>    create_mesh()    = 0;
        virtual std::unique_ptr<ITexture> create_texture() = 0;
        virtual std::unique_ptr<IShader>  create_shader()  = 0;
        virtual ~IRenderFactory() = default;
    };

    // OpenGL backend
    struct GLMesh    : IMesh    { void upload()  override { /* glBufferData */ } };
    struct GLTexture : ITexture { void bind()    override { /* glBindTexture */ } };
    struct GLShader  : IShader  { void compile() override { /* glCompileShader */ } };
    struct GLFactory : IRenderFactory {
        std::unique_ptr<IMesh>    create_mesh()    override { return std::make_unique<GLMesh>(); }
        std::unique_ptr<ITexture> create_texture() override { return std::make_unique<GLTexture>(); }
        std::unique_ptr<IShader>  create_shader()  override { return std::make_unique<GLShader>(); }
    };

    // Vulkan backend (same structure)
    struct VkMesh    : IMesh    { void upload()  override { /* vkCmdCopyBuffer */ } };
    struct VkTexture : ITexture { void bind()    override { /* descriptor set */ } };
    struct VkShader  : IShader  { void compile() override { /* vkCreateShaderModule */ } };
    struct VkFactory : IRenderFactory {
        std::unique_ptr<IMesh>    create_mesh()    override { return std::make_unique<VkMesh>(); }
        std::unique_ptr<ITexture> create_texture() override { return std::make_unique<VkTexture>(); }
        std::unique_ptr<IShader>  create_shader()  override { return std::make_unique<VkShader>(); }
    };

    class RenderSystem {
    public:
        static RenderSystem& instance() {
            static RenderSystem inst;
            return inst;
        }

        void initialize(std::unique_ptr<IRenderFactory> f) {
            std::unique_lock lock(mutex_);
            if (initialized_.load(std::memory_order_acquire))
                throw std::logic_error("RenderSystem already initialized");
            factory_ = std::move(f);
            initialized_.store(true, std::memory_order_release);
        }

        std::unique_ptr<IMesh>    create_mesh() {
            std::shared_lock lock(mutex_);
            ensure_initialized();
            return factory_->create_mesh();
        }

        std::unique_ptr<ITexture> create_texture() {
            std::shared_lock lock(mutex_);
            ensure_initialized();
            return factory_->create_texture();
        }

        std::unique_ptr<IShader>  create_shader() {
            std::shared_lock lock(mutex_);
            ensure_initialized();
            return factory_->create_shader();
        }

        RenderSystem(const RenderSystem&)            = delete;
        RenderSystem& operator=(const RenderSystem&) = delete;

    private:
        RenderSystem() = default;

        void ensure_initialized() const {
            if (!initialized_.load(std::memory_order_acquire))
                throw std::logic_error("RenderSystem not initialized");
        }

        mutable std::shared_mutex mutex_;
        std::atomic<bool> initialized_{false};
        std::unique_ptr<IRenderFactory> factory_;
    };

    // Usage:
    // RenderSystem::instance().initialize(std::make_unique<GLFactory>());
    // auto mesh = RenderSystem::instance().create_mesh();

─── STEP 5: WHEN TO USE ────────────────────────────────────────────────────────────
    - Cross-platform backends: OpenGL/Vulkan/Metal, Win32/Cocoa/X11.
    - Database drivers: MySQL/PostgreSQL/SQLite — all using the same IConnection interface.
    - Theme/skin systems: create all widgets with the same visual style at once.
    - Test doubles: swap in a MockFactory during tests to avoid constructing real resources.
    - Game engines: swap physics engine or audio backend without changing game logic.

─── STEP 6: WHEN NOT TO USE ────────────────────────────────────────────────────────
    - When you only have one concrete family now and cannot foresee another.
    - When the products in the family are independent — use separate Factory Methods instead.
    - When adding a new product type to the factory requires changing IUIFactory and all subclasses.

─── STEP 7: COMMON MISTAKES ────────────────────────────────────────────────────────
    - Adding a method to the abstract factory for every new widget type — breaks Open/Closed Principle.
