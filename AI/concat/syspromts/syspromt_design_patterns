    class PluginRegistry {
    public:
        struct IPlugin {
            virtual ~IPlugin() = default;
            virtual void execute()      = 0;
            virtual std::string name()  const = 0;
        };

        // Meyers Singleton — thread-safe initialization
        static PluginRegistry& instance() {
            static PluginRegistry inst;
            return inst;
        }

        // Register a plugin — write lock
        void register_plugin(std::shared_ptr<IPlugin> plugin) {
            std::unique_lock lock(rw_mutex_);
            const auto key = plugin->name();
            if (plugins_.count(key)) throw std::runtime_error("Duplicate plugin: " + key);
            plugins_[key] = std::move(plugin);
        }

        // Lookup — read lock (multiple readers allowed concurrently)
        std::shared_ptr<IPlugin> get(const std::string& name) const {
            std::shared_lock lock(rw_mutex_);
            auto it = plugins_.find(name);
            if (it == plugins_.end()) throw std::runtime_error("Plugin not found: " + name);
            return it->second;
        }

        // Execute all plugins — read lock
        void execute_all() const {
            std::shared_lock lock(rw_mutex_);
            for (const auto& [name, plugin] : plugins_) plugin->execute();
        }

        PluginRegistry(const PluginRegistry&)            = delete;
        PluginRegistry& operator=(const PluginRegistry&) = delete;

    private:
        PluginRegistry() = default;
        mutable std::shared_mutex rw_mutex_;
        std::unordered_map<std::string, std::shared_ptr<IPlugin>> plugins_;
    };

    // Concrete plugin
    class AudioPlugin : public PluginRegistry::IPlugin {
    public:
        void execute()     override { /* process audio */ }
        std::string name() const override { return "audio"; }
    };

