    class TSUIFactoryProvider {
    public:
        static TSUIFactoryProvider& instance() {
            static TSUIFactoryProvider inst;
            return inst;
        }
        // Called once before threads start — no lock needed, but guarded anyway
        void set_factory(std::unique_ptr<IUIFactory> f) {
            std::unique_lock lock(mutex_);
            if (factory_) throw std::logic_error("Factory already set");
            factory_ = std::move(f);
        }
        // Called concurrently from any thread — shared read lock
        std::unique_ptr<IButton> create_button() {
            std::shared_lock lock(mutex_);
            return factory_->create_button();
        }
        std::unique_ptr<ITextBox> create_textbox() {
            std::shared_lock lock(mutex_);
            return factory_->create_textbox();
        }
        TSUIFactoryProvider(const TSUIFactoryProvider&)            = delete;
        TSUIFactoryProvider& operator=(const TSUIFactoryProvider&) = delete;
    private:
        TSUIFactoryProvider() = default;
        mutable std::shared_mutex mutex_;
        std::unique_ptr<IUIFactory> factory_;
    };

