/**
 * @file   discount_engine.hpp
 * @brief  Extensible discount calculation engine.
 *
 * Design Principle: Open/Closed Principle (OCP).
 *
 * New discount types are added by creating a new class that implements
 * IDiscountRule — the DiscountEngine itself is never modified. This means
 * the engine is battle-tested and stable; only the new rule class is new
 * and therefore the only code that needs review and testing for a new feature.
 *
 * Thread Safety:
 *   - IDiscountRule implementations must be stateless or internally
 *     synchronized if used concurrently.
 *   - DiscountEngine itself is thread-safe for concurrent apply() calls
 *     once rules are added; add_rule() is not thread-safe and must be
 *     called before any concurrent apply() calls.
 */

#pragma once
#include <memory>
#include <vector>
#include <string>
#include <stdexcept>

namespace pricing {

/// The order context passed to every discount rule.
struct OrderContext {
    std::string customer_id;      ///< Unique customer identifier.
    std::string product_category; ///< E.g., "electronics", "clothing".
    double      subtotal;         ///< Pre-discount total in USD. Must be >= 0.
    int         item_count;       ///< Number of line items. Must be >= 1.
    bool        is_member;        ///< Whether the customer holds a membership.
};

/**
 * @interface IDiscountRule
 * @brief     Contract for a single, composable discount rule.
 *
 * Each implementation represents ONE discount policy. Rules are composed
 * inside DiscountEngine without any of them knowing about the others.
 *
 * Implementors MUST:
 *   - Return a discount amount >= 0 and <= ctx.subtotal.
 *   - Be pure functions of ctx (no side effects, no state mutation).
 *   - Not throw exceptions for normal inputs.
 */
struct IDiscountRule {
    virtual ~IDiscountRule() = default;

    /**
     * @brief  Computes the discount amount this rule grants for the given order.
     *
     * @param  ctx  The full order context.
     * @return      Discount amount in USD. 0.0 means this rule does not apply.
     *
     * @post   return value >= 0.0
     * @post   return value <= ctx.subtotal
     */
    [[nodiscard]]
    virtual double compute_discount(const OrderContext& ctx) const noexcept = 0;

    /**
     * @brief  Human-readable description of this rule.
     * @return Non-empty string. Used for logging and audit trails.
     */
    [[nodiscard]]
    virtual std::string description() const noexcept = 0;
};

/**
 * @struct DiscountBreakdown
 * @brief  Result of applying all registered rules to one order.
 */
struct DiscountBreakdown {
    double total_discount;  ///< Sum of all individual discounts, capped at subtotal.
    double final_price;     ///< ctx.subtotal - total_discount.
    /// Each applied rule and the amount it contributed.
    std::vector<std::pair<std::string, double>> applied_rules;
};

/**
 * @class DiscountEngine
 * @brief Applies a set of registered IDiscountRule objects to an order.
 *
 * OCP: This class is closed for modification. To add a new discount,
 * implement IDiscountRule and call add_rule(). The engine code does not change.
 *
 * Usage:
 * @code
 *   DiscountEngine engine;
 *   engine.add_rule(std::make_unique<MemberDiscountRule>(0.10));
 *   engine.add_rule(std::make_unique<BulkDiscountRule>(10, 0.05));
 *   auto result = engine.apply(ctx);
 * @endcode
 */
class DiscountEngine {
public:
    /**
     * @brief  Registers a new discount rule with the engine.
     *
     * @param  rule  Non-null owning pointer to a rule. The engine takes ownership.
     *
     * @throws std::invalid_argument if rule is nullptr.
     *
     * @note   Not thread-safe. Call before any concurrent apply() invocations.
     */
    void add_rule(std::unique_ptr<IDiscountRule> rule);

    /**
     * @brief  Applies all registered rules to the given order context.
     *
     * Rules are applied independently and their discounts are summed.
     * The total discount is capped at ctx.subtotal so final_price >= 0.
     *
     * @param  ctx  The order to evaluate. ctx.subtotal must be >= 0.
     *
     * @return      Full breakdown of which rules fired and by how much.
     *
     * @throws std::invalid_argument if ctx.subtotal < 0.
     *
     * @note   Thread-safe for concurrent calls once construction is complete.
     */
    [[nodiscard]]
    DiscountBreakdown apply(const OrderContext& ctx) const;

    /// Returns the number of rules currently registered.
    [[nodiscard]]
    std::size_t rule_count() const noexcept;
};

// ── Built-in rule implementations (open for use, closed for modification) ────

/**
 * @class MemberDiscountRule
 * @brief Grants a percentage discount to customers with membership.
 *
 * Applies only when OrderContext::is_member == true.
 */
class MemberDiscountRule : public IDiscountRule {
public:
    /**
     * @brief  Constructs a membership discount rule.
     * @param  rate  Discount rate in [0.0, 1.0]. E.g., 0.10 = 10%.
     * @throws std::invalid_argument if rate is outside [0.0, 1.0].
     */
    explicit MemberDiscountRule(double rate);

    [[nodiscard]] double      compute_discount(const OrderContext& ctx) const noexcept override;
    [[nodiscard]] std::string description()      const noexcept override;

private:
    double rate_;
};

/**
 * @class BulkDiscountRule
 * @brief Grants a percentage discount when the order contains >= min_items.
 */
class BulkDiscountRule : public IDiscountRule {
public:
    /**
     * @brief  Constructs a bulk discount rule.
     * @param  min_items  Minimum item count required for the discount.
     * @param  rate       Discount rate in [0.0, 1.0].
     * @throws std::invalid_argument if min_items < 1 or rate outside [0, 1].
     */
    BulkDiscountRule(int min_items, double rate);

    [[nodiscard]] double      compute_discount(const OrderContext& ctx) const noexcept override;
    [[nodiscard]] std::string description()      const noexcept override;

private:
    int    min_items_;
    double rate_;
};

/**
 * @class CategoryDiscountRule
 * @brief Grants a flat percentage discount on a specific product category.
 */
class CategoryDiscountRule : public IDiscountRule {
public:
    /**
     * @param  category  The product category to match (case-sensitive).
     * @param  rate      Discount rate in [0.0, 1.0].
     * @throws std::invalid_argument if category is empty or rate outside [0, 1].
     */
    CategoryDiscountRule(std::string category, double rate);

    [[nodiscard]] double      compute_discount(const OrderContext& ctx) const noexcept override;
    [[nodiscard]] std::string description()      const noexcept override;

private:
    std::string category_;
    double      rate_;
};

} // namespace pricing

