// Design Principle Applied: Open/Closed Principle (OCP)
// To add a new discount: write a new IDiscountRule subclass.
// This file is never edited when new discount types are added.

#include "discount_engine.hpp"
#include <stdexcept>
#include <numeric>
#include <algorithm>
#include <sstream>

namespace pricing {

void DiscountEngine::add_rule(std::unique_ptr<IDiscountRule> rule) {
    if (!rule) throw std::invalid_argument("add_rule: rule must not be null");
    rules_.push_back(std::move(rule));
}

DiscountBreakdown DiscountEngine::apply(const OrderContext& ctx) const {
    if (ctx.subtotal < 0.0)
        throw std::invalid_argument("apply: subtotal must be >= 0");

    DiscountBreakdown result{};

    for (const auto& rule : rules_) {
        double discount = rule->compute_discount(ctx);
        // Each rule is responsible for returning a valid discount,
        // but we clamp defensively to guard against buggy implementations.
        discount = std::clamp(discount, 0.0, ctx.subtotal);
        if (discount > 0.0) {
            result.applied_rules.emplace_back(rule->description(), discount);
            result.total_discount += discount;
        }
    }

    // Cap total discount so final price never goes negative.
    result.total_discount = std::min(result.total_discount, ctx.subtotal);
    result.final_price    = ctx.subtotal - result.total_discount;
    return result;
}

std::size_t DiscountEngine::rule_count() const noexcept { return rules_.size(); }

