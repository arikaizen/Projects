/**
 * @file   report_generator.hpp
 * @brief  Pure report-data assembly. No I/O, no formatting, no persistence.
 *
 * Design Principle: Single Responsibility Principle (SRP).
 * This class has exactly one job: transform a collection of raw Sale records
 * into a ReportData aggregate. It does not know how the report will be
 * formatted or where it will be written. Those are separate responsibilities
 * handled by IReportFormatter and IReportWriter respectively.
 *
 * Thread Safety: All methods are const and stateless after construction.
 *                Safe to call from multiple threads concurrently.
 *
 * Ownership: Input data is passed by const-ref. Output is returned by value.
 */

#pragma once
#include <vector>
#include <string>
#include <chrono>
#include <optional>
#include <stdexcept>

namespace reporting {

/// A single sales transaction record.
struct Sale {
    std::string product_id;   ///< Unique product identifier.
    double      unit_price;   ///< Price per unit in USD. Must be >= 0.
    int         quantity;     ///< Number of units sold. Must be > 0.
    std::chrono::system_clock::time_point timestamp; ///< When the sale occurred.
};

/// Aggregated report output — pure data, no formatting.
struct ReportData {
    double      total_revenue;      ///< Sum of all sale values.
    double      average_sale_value; ///< Mean value per transaction.
    double      max_sale_value;     ///< Highest single transaction value.
    double      min_sale_value;     ///< Lowest single transaction value.
    std::size_t transaction_count;  ///< Total number of sales processed.
    std::string top_product_id;     ///< Product ID with highest total revenue.
};

/**
 * @class ReportGenerator
 * @brief Assembles a ReportData from a list of Sale records.
 *
 * SRP: This class only computes report statistics. It does not format
 * the report into text, does not write it to a file or stream, and does
 * not fetch data from a database. Those concerns are handled elsewhere.
 *
 * Usage:
 * @code
 *   ReportGenerator gen;
 *   auto data = gen.generate(sales);
 *   // Pass data to a formatter, then to a writer.
 * @endcode
 */
class ReportGenerator {
public:
    /**
     * @brief Generates a statistical summary from a list of sales.
     *
     * @param sales  Non-empty collection of Sale records to aggregate.
     *
     * @return       Fully populated ReportData aggregate.
     *
     * @throws std::invalid_argument if sales is empty.
     * @throws std::domain_error     if any sale has a negative unit_price
     *                               or non-positive quantity.
     *
     * @pre  sales.size() >= 1
     * @pre  For all s in sales: s.unit_price >= 0 && s.quantity > 0
     * @post result.transaction_count == sales.size()
     * @post result.total_revenue >= 0
     */
    [[nodiscard]]
    ReportData generate(const std::vector<Sale>& sales) const;

    /**
     * @brief Filters a sale collection to a specific time window.
     *
     * @param sales  Source collection. Not modified.
     * @param from   Start of the window (inclusive).
     * @param to     End of the window (inclusive).
     *
     * @return       Subset of sales whose timestamp falls within [from, to].
     *               Returns an empty vector if no sales match; never throws.
     *
     * @pre  from <= to
     */
    [[nodiscard]]
    std::vector<Sale> filter_by_date(
        const std::vector<Sale>& sales,
        std::chrono::system_clock::time_point from,
        std::chrono::system_clock::time_point to) const noexcept;
};

} // namespace reporting

