// Design Principle Applied: Single Responsibility Principle (SRP)
// This translation unit contains ONLY statistical computation logic.
// It has no knowledge of output format, storage, or transport.

#include "report_generator.hpp"
#include <algorithm>
#include <numeric>
#include <unordered_map>
#include <stdexcept>
#include <limits>

namespace reporting {

ReportData ReportGenerator::generate(const std::vector<Sale>& sales) const {
    if (sales.empty())
        throw std::invalid_argument("generate: sales collection must not be empty");

    // Validate all records upfront so callers get a clear error message
    // before any partial computation occurs.
    for (const auto& s : sales) {
        if (s.unit_price < 0.0)
            throw std::domain_error("generate: unit_price must be >= 0 for product " + s.product_id);
        if (s.quantity <= 0)
            throw std::domain_error("generate: quantity must be > 0 for product " + s.product_id);
    }

    ReportData result{};
    result.transaction_count = sales.size();
    result.min_sale_value    = std::numeric_limits<double>::max();
    result.max_sale_value    = std::numeric_limits<double>::lowest();

    // Accumulate per-product revenue to find the top performer.
    std::unordered_map<std::string, double> product_revenue;

    for (const auto& s : sales) {
        const double value = s.unit_price * static_cast<double>(s.quantity);
        result.total_revenue        += value;
        result.min_sale_value        = std::min(result.min_sale_value, value);
        result.max_sale_value        = std::max(result.max_sale_value, value);
        product_revenue[s.product_id] += value;
    }

    result.average_sale_value = result.total_revenue / static_cast<double>(sales.size());

    // Find the product with the highest cumulative revenue.
    auto top_it = std::max_element(
        product_revenue.begin(), product_revenue.end(),
        [](const auto& a, const auto& b){ return a.second < b.second; });
    result.top_product_id = top_it->first;

    return result;
}

std::vector<Sale> ReportGenerator::filter_by_date(
    const std::vector<Sale>& sales,
    std::chrono::system_clock::time_point from,
    std::chrono::system_clock::time_point to) const noexcept
{
    std::vector<Sale> result;
    result.reserve(sales.size()); // avoid reallocations — we may keep most records
    std::copy_if(sales.begin(), sales.end(), std::back_inserter(result),
        [&](const Sale& s){ return s.timestamp >= from && s.timestamp <= to; });
    return result;
}

} // namespace reporting

