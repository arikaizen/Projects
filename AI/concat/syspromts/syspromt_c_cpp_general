PATTERN 10 — COMMAND
─────────────────────────────────────────────────────────
Intent: Encapsulate a request as an object, allowing undo/redo, queuing, and logging.
Use when: Text editor undo/redo, transaction systems, task schedulers, macro recording.
Do NOT use when: Simple function calls with no need for history or queuing.

    struct ICommand {
        virtual ~ICommand() = default;
        virtual void execute() = 0;
        virtual void undo()    = 0;
    };

    class TextEditor {
    public:
        void insertText(std::size_t pos, std::string text) {
            text_.insert(pos, text);
        }
        void deleteText(std::size_t pos, std::size_t len) {
            text_.erase(pos, len);
        }
        const std::string& text() const { return text_; }
    private:
        std::string text_;
    };

    class InsertCommand : public ICommand {
    public:
        InsertCommand(TextEditor& ed, std::size_t pos, std::string text)
            : ed_(ed), pos_(pos), text_(std::move(text)) {}
        void execute() override { ed_.insertText(pos_, text_); }
        void undo()    override { ed_.deleteText(pos_, text_.size()); }
    private:
        TextEditor& ed_;
        std::size_t pos_;
        std::string text_;
    };

    class CommandHistory {
    public:
        void execute(std::unique_ptr<ICommand> cmd) {
            cmd->execute();
            history_.push(std::move(cmd));
        }
        void undo() {
            if (!history_.empty()) {
                history_.top()->undo();
                history_.pop();
            }
        }
    private:
        std::stack<std::unique_ptr<ICommand>> history_;
    };

