PATTERN 8 — OBSERVER
─────────────────────────────────────────────────────────
Intent: Define a one-to-many dependency so when one object changes state,
        all dependents are notified.
Use when: Event systems, GUI callbacks, pub/sub, reactive data pipelines.
Do NOT use when: There is a fixed single listener — just call it directly.

    struct IObserver {
        virtual ~IObserver() = default;
        virtual void onEvent(std::string_view event) = 0;
    };

    class EventSource {
    public:
        void subscribe(IObserver* obs) { observers_.push_back(obs); }
        void unsubscribe(IObserver* obs) {
            observers_.erase(std::remove(observers_.begin(), observers_.end(), obs),
                             observers_.end());
        }
    protected:
        void notify(std::string_view event) {
            for (auto* o : observers_) o->onEvent(event);
        }
    private:
        std::vector<IObserver*> observers_;  // non-owning
    };

