PATTERN 3 — ABSTRACT FACTORY
─────────────────────────────────────────────────────────
Intent: Provide an interface for creating families of related objects without specifying concrete classes.
Use when: Cross-platform UI widgets, render backends (OpenGL vs Vulkan), database drivers.
Do NOT use when: You only have one family — use Factory Method instead.

    struct Button  { virtual ~Button()  = default; virtual void render() = 0; };
    struct Checkbox{ virtual ~Checkbox()= default; virtual void render() = 0; };

    struct GUIFactory {
        virtual ~GUIFactory() = default;
        virtual std::unique_ptr<Button>   createButton()   = 0;
        virtual std::unique_ptr<Checkbox> createCheckbox() = 0;
    };

    struct WinButton  : Button   { void render() override { /* Win32 */ } };
    struct WinCheckbox: Checkbox { void render() override { /* Win32 */ } };
    struct WinFactory : GUIFactory {
        std::unique_ptr<Button>   createButton()   override { return std::make_unique<WinButton>(); }
        std::unique_ptr<Checkbox> createCheckbox() override { return std::make_unique<WinCheckbox>(); }
    };

