PATTERN 13 — PIMPL (Pointer to Implementation)
─────────────────────────────────────────────────────────
Intent: Hide implementation details behind an opaque pointer to reduce compilation dependencies
        and provide ABI stability.
Use when: Public library APIs, reducing header dependencies, hiding platform-specific code.
Do NOT use when: The class is not part of a public API and compile times are not a concern.

    // foo.hpp — public header, no implementation details exposed
    #pragma once
    #include <memory>
    class Foo {
    public:
        Foo();
        ~Foo();
        Foo(Foo&&) noexcept;
        Foo& operator=(Foo&&) noexcept;
        void doSomething();
    private:
        struct Impl;
        std::unique_ptr<Impl> pimpl_;
    };

    // foo.cpp — implementation translation unit
    #include "foo.hpp"
    #include <iostream>
    struct Foo::Impl {
        int value = 42;
        void doSomethingImpl() { std::cout << "value=" << value << '\n'; }
    };
    Foo::Foo()  : pimpl_(std::make_unique<Impl>()) {}
    Foo::~Foo() = default;
    Foo::Foo(Foo&&) noexcept = default;
    Foo& Foo::operator=(Foo&&) noexcept = default;
    void Foo::doSomething() { pimpl_->doSomethingImpl(); }

