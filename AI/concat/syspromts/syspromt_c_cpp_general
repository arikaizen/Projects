PATTERN 5 — PROTOTYPE
─────────────────────────────────────────────────────────
Intent: Create new objects by cloning an existing prototype.
Use when: Object construction is expensive and a similar object already exists;
          used in game engines for entity spawning, document templates.
Do NOT use when: Construction is cheap — just construct normally.

    struct Enemy {
        virtual ~Enemy() = default;
        virtual std::unique_ptr<Enemy> clone() const = 0;
        virtual void print() const = 0;
        int hp = 100;
        float speed = 1.0f;
    };

    struct Goblin : Enemy {
        std::unique_ptr<Enemy> clone() const override {
            return std::make_unique<Goblin>(*this);
        }
        void print() const override {
            std::cout << "Goblin hp=" << hp << " speed=" << speed << '\n';
        }
    };

