PATTERN 11 — STATE
─────────────────────────────────────────────────────────
Intent: Allow an object to alter its behavior when its internal state changes.
Use when: Vending machines, network connection lifecycle, UI mode switching, parsers.
Do NOT use when: There are only 2 states — a simple bool flag is cleaner.

    struct TrafficLight;
    struct State {
        virtual ~State() = default;
        virtual void handle(TrafficLight&) = 0;
        virtual std::string name() const = 0;
    };

    struct TrafficLight {
        void setState(std::unique_ptr<State> s) { state_ = std::move(s); }
        void request() { state_->handle(*this); }
        std::string currentState() const { return state_->name(); }
    private:
        std::unique_ptr<State> state_;
    };

    struct GreenState : State {
        void handle(TrafficLight& tl) override;
        std::string name() const override { return "Green"; }
    };
    struct YellowState : State {
        void handle(TrafficLight& tl) override;
        std::string name() const override { return "Yellow"; }
    };
    struct RedState : State {
        void handle(TrafficLight& tl) override;
        std::string name() const override { return "Red"; }
    };

    void GreenState ::handle(TrafficLight& tl) { tl.setState(std::make_unique<YellowState>()); }
    void YellowState::handle(TrafficLight& tl) { tl.setState(std::make_unique<RedState>());   }
    void RedState   ::handle(TrafficLight& tl) { tl.setState(std::make_unique<GreenState>()); }

