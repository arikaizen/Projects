PATTERN 7 — DECORATOR
─────────────────────────────────────────────────────────
Intent: Add responsibilities to objects dynamically without subclassing.
Use when: Layered streams (buffered + encrypted + compressed), middleware pipelines.
Do NOT use when: Behavior is static — use inheritance or composition directly.

    struct DataSource {
        virtual ~DataSource() = default;
        virtual void write(std::string_view data) = 0;
        virtual std::string read() = 0;
    };

    class FileDataSource : public DataSource {
    public:
        explicit FileDataSource(std::string path) : path_(std::move(path)) {}
        void write(std::string_view data) override { /* write to file */ }
        std::string read() override { return ""; /* read from file */ }
    private:
        std::string path_;
    };

    class EncryptionDecorator : public DataSource {
    public:
        explicit EncryptionDecorator(std::unique_ptr<DataSource> src) : src_(std::move(src)) {}
        void write(std::string_view data) override {
            src_->write(encrypt(data));
        }
        std::string read() override { return decrypt(src_->read()); }
    private:
        std::unique_ptr<DataSource> src_;
        std::string encrypt(std::string_view s) { return std::string(s) + "_enc"; }
        std::string decrypt(std::string s)       { return s; }
    };

