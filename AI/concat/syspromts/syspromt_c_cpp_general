PATTERN 6 — ADAPTER
─────────────────────────────────────────────────────────
Intent: Convert the interface of a class into another interface clients expect.
Use when: Integrating a third-party library whose interface does not match yours.
Do NOT use when: You control both interfaces — redesign instead.

    // Existing incompatible interface
    struct LegacyLogger {
        void writeLog(int level, const char* msg) { /* ... */ }
    };

    // Target interface
    struct ILogger {
        virtual ~ILogger() = default;
        virtual void info(std::string_view msg)  = 0;
        virtual void error(std::string_view msg) = 0;
    };

    // Adapter
    class LegacyLoggerAdapter : public ILogger {
    public:
        explicit LegacyLoggerAdapter(LegacyLogger& leg) : leg_(leg) {}
        void info (std::string_view msg) override { leg_.writeLog(0, msg.data()); }
        void error(std::string_view msg) override { leg_.writeLog(2, msg.data()); }
    private:
        LegacyLogger& leg_;
    };

