PATTERN 15 — TYPE ERASURE
─────────────────────────────────────────────────────────
Intent: Store objects of different types that share a behavioral contract without a common base class.
Use when: std::function-like containers, plugin systems, heterogeneous collections.
Do NOT use when: All types are known — use templates or virtual dispatch.

    // A type-erased "callable that returns int"
    class AnyIntCallable {
    public:
        template <typename F>
        AnyIntCallable(F f) : self_(std::make_unique<Model<F>>(std::move(f))) {}

        int operator()() const { return self_->invoke(); }

    private:
        struct Concept { virtual ~Concept() = default; virtual int invoke() const = 0; };
        template <typename F>
        struct Model : Concept {
            explicit Model(F f) : f_(std::move(f)) {}
            int invoke() const override { return f_(); }
            F f_;
        };
        std::unique_ptr<Concept> self_;
    };

