PATTERN 12 — TEMPLATE METHOD
─────────────────────────────────────────────────────────
Intent: Define the skeleton of an algorithm in a base class, defer specific steps to subclasses.
Use when: Report generation, data parsing pipelines, game loop step overriding.
Do NOT use when: The algorithm does not have a fixed skeleton — use Strategy instead.

    class DataMiner {
    public:
        // Template method — final to prevent override of the skeleton
        void mine(const std::string& path) {
            auto raw  = extractData(path);
            auto data = parseData(raw);
            analyzeData(data);
            sendReport(data);
        }
    protected:
        virtual std::string             extractData(const std::string& path) = 0;
        virtual std::vector<double>     parseData(const std::string& raw)    = 0;
        virtual void                    analyzeData(const std::vector<double>&) {}
    private:
        void sendReport(const std::vector<double>& data) { /* common reporting */ }
    };

    class CSVMiner : public DataMiner {
    protected:
        std::string extractData(const std::string& path) override { return "csv_raw"; }
        std::vector<double> parseData(const std::string&) override { return {1.0, 2.0}; }
    };

