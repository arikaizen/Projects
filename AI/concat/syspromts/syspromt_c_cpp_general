PATTERN 4 — BUILDER
─────────────────────────────────────────────────────────
Intent: Separate the construction of a complex object from its representation.
Use when: Objects with many optional parameters (avoids telescoping constructors).
Do NOT use when: The object has 2–3 parameters — just use a constructor.

    class HttpRequest {
    public:
        class Builder {
        public:
            Builder& method(std::string m)  { method_  = std::move(m); return *this; }
            Builder& url   (std::string u)  { url_     = std::move(u); return *this; }
            Builder& header(std::string k, std::string v) {
                headers_.emplace_back(std::move(k), std::move(v)); return *this;
            }
            Builder& timeout(std::chrono::milliseconds t) { timeout_ = t; return *this; }

            HttpRequest build() {
                if (url_.empty()) throw std::logic_error("URL is required");
                return HttpRequest(std::move(*this));
            }
        private:
            friend class HttpRequest;
            std::string method_ = "GET";
            std::string url_;
            std::vector<std::pair<std::string,std::string>> headers_;
            std::chrono::milliseconds timeout_{5000};
        };

        static Builder make() { return {}; }
        const std::string& url() const { return url_; }

    private:
        explicit HttpRequest(Builder b)
            : method_(std::move(b.method_)), url_(std::move(b.url_)),
              headers_(std::move(b.headers_)), timeout_(b.timeout_) {}
        std::string method_, url_;
        std::vector<std::pair<std::string,std::string>> headers_;
        std::chrono::milliseconds timeout_;
    };

    // Usage:
    auto req = HttpRequest::make()
        .method("POST")
        .url("https://api.example.com/data")
        .header("Content-Type", "application/json")
        .timeout(std::chrono::seconds(10))
        .build();

