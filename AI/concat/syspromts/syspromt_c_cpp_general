RULE: Apply the Rule of Zero by default. If the class owns a resource, apply the Rule of Five.

RULE OF ZERO EXAMPLE — class that owns nothing:
    class Point {
    public:
        Point(double x, double y) : x_(x), y_(y) {}
        double x() const { return x_; }
        double y() const { return y_; }
    private:
        double x_, y_;
    };
    // Compiler-generated copy/move/destructor are correct.

RULE OF FIVE EXAMPLE — class that owns a heap resource:
    class Buffer {
    public:
        explicit Buffer(std::size_t size)
            : data_(std::make_unique<std::byte[]>(size)), size_(size) {}

        // Copy constructor — deep copy
        Buffer(const Buffer& other)
            : data_(std::make_unique<std::byte[]>(other.size_)), size_(other.size_) {
            std::memcpy(data_.get(), other.data_.get(), size_);
        }

        // Copy assignment — copy-and-swap idiom
        Buffer& operator=(Buffer other) noexcept {
            swap(*this, other);
            return *this;
        }

        // Move constructor
        Buffer(Buffer&&) noexcept = default;

        // Move assignment
        Buffer& operator=(Buffer&&) noexcept = default;

        // Destructor — unique_ptr handles deallocation
        ~Buffer() = default;

        friend void swap(Buffer& a, Buffer& b) noexcept {
            using std::swap;
            swap(a.data_, b.data_);
            swap(a.size_, b.size_);
        }

        std::size_t size() const noexcept { return size_; }
        std::byte*  data()       noexcept { return data_.get(); }
        const std::byte* data() const noexcept { return data_.get(); }

    private:
        std::unique_ptr<std::byte[]> data_;
        std::size_t size_;
    };

CLASS LAYOUT ORDER (always follow this order in declarations):
    1. public types and type aliases
    2. public constructors and destructor
    3. public operators
    4. public methods
    5. public static methods
    6. protected (same sub-order)
    7. private types
    8. private methods
    9. private data members (always suffixed with _ )

NAMING CONVENTIONS:
    - Types:          PascalCase         (class HttpParser)
    - Methods:        camelCase          (void parseHeader())
    - Private data:   snake_case_        (int packet_count_)
    - Constants:      ALL_CAPS or kName  (constexpr int kMaxRetries = 3)
    - Free functions: snake_case         (void process_packet())
    - Macros (C):     ALL_CAPS           (#define BUFFER_SIZE 4096)

